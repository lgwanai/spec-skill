{
  "project": {
    "name": "[Project Name]",
    "version": "1.0.0",
    "description": "[Project description]",
    "repository": "[Git repository URL]"
  },

  "mode": "interactive",
  "granularity": "standard",

  "workflow": {
    "auto_commit": true,
    "commit_message_template": "feat: {phase}-{plan}: {description}",
    "require_verification": true,
    "verification_types": ["automated", "manual", "integration"],
    "create_summaries": true,
    "update_state": true,
    "research": true,
    "plan_check": true,
    "verifier": true,
    "auto_advance": false,
    "nyquist_validation": true,
    "security_enforcement": true,
    "security_asvs_level": 1,
    "security_block_on": "high",
    "discuss_mode": "discuss",
    "research_before_questions": false,
    "code_review_command": null,
    "plan_bounce": false,
    "plan_bounce_script": null,
    "plan_bounce_passes": 2,
    "cross_ai_execution": false,
    "cross_ai_command": "",
    "cross_ai_timeout": 300
  },

  "quality": {
    "test_coverage_threshold": 80,
    "require_linting": true,
    "require_type_checking": true,
    "require_formatting": true,
    "code_quality_checks": ["eslint", "prettier", "typescript"]
  },

  "planning": {
    "commit_docs": true,
    "search_gitignored": false,
    "sub_repos": []
  },

  "phases": {
    "max_plans_per_phase": 5,
    "default_wave_size": 2,
    "allow_parallel_execution": true,
    "require_dependency_resolution": true,
    "auto_number_requirements": true
  },

  "parallelization": {
    "enabled": true,
    "plan_level": true,
    "task_level": false,
    "skip_checkpoints": true,
    "max_concurrent_agents": 3,
    "min_plans_for_parallel": 2
  },

  "gates": {
    "confirm_project": true,
    "confirm_phases": true,
    "confirm_roadmap": true,
    "confirm_breakdown": true,
    "confirm_plan": true,
    "execute_next_plan": true,
    "issues_review": true,
    "confirm_transition": true
  },

  "safety": {
    "always_confirm_destructive": true,
    "always_confirm_external_services": true
  },

  "hooks": {
    "context_warnings": true
  },

  "verification": {
    "automated_tests": true,
    "manual_verification": true,
    "integration_tests": true,
    "performance_tests": false,
    "security_scan": false
  },

  "documentation": {
    "update_readme": true,
    "create_api_docs": false,
    "maintain_changelog": true,
    "document_decisions": true
  },

  "notifications": {
    "phase_completion": true,
    "verification_failure": true,
    "blocker_detected": true,
    "milestone_reached": true
  },

  "integrations": {
    "git": true,
    "ci_cd": false,
    "project_management": false,
    "monitoring": false
  },

  "project_code": null,
  "agent_skills": {},
  "claude_md_path": "./CLAUDE.md"
}
